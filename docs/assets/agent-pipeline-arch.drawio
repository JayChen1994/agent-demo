        <mxCell id="sq_regarrow" style="html=1;endArrow=block;dashed=1;rounded=0;fontSize=12;startArrow=none;strokeColor=#d6b656;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1050" y="200" as="sourcePoint" /><mxPoint x="1050" y="215" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Phase B: config messages -->
        <mxCell id="sq_mB1" value="GET /pipeline/steps" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="260" as="sourcePoint" /><mxPoint x="450" y="260" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB2" value="list_steps()" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="450" y="310" as="sourcePoint" /><mxPoint x="750" y="310" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB3" value="读取注册表" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="750" y="360" as="sourcePoint" /><mxPoint x="1050" y="360" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB4" value="StepInfo[]（kind / inputs / outputs / group / default_enabled）" style="html=1;endArrow=open;dashed=1;endFill=0;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1050" y="410" as="sourcePoint" /><mxPoint x="150" y="410" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB5" value="GET /pipeline/templates" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="470" as="sourcePoint" /><mxPoint x="450" y="470" as="targetPoint" /></mxGeometry></mxCell>
