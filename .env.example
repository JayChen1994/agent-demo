# 复制为 .env 后按需修改
APP_NAME=agent-demo
ENV=dev
DEBUG=true
API_PREFIX=/api/v1
HOST=127.0.0.1
PORT=8000

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=agent_demo
DB_ECHO=false

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 日志
LOG_LEVEL=INFO
LOG_DIR=logs

# 真实 LLM（Gemini via google-genai）
GOOGLE_API_KEYS=         # 多个 key 用英文逗号分隔
GEMINI_BACKEND=vertex_ai # vertex_ai | google_ai
GOOGLE_CLOUD_LOCATION=us-central1
LLM_MODEL=gemini-3.1-pro-preview
LLM_THINKING_LEVEL=low   # low（demo 更快）| high（质量更好）

# 真实生图（portrait_gen 网关）
PORTRAIT_GEN_BASE_URL=   # 例：http://192.168.x.x:8003
PORTRAIT_GEN_PROVIDER=openai
PORTRAIT_GEN_MODEL_ID=openai:t2i_image_2
PORTRAIT_GEN_MODEL=text2image_gpt_image_2
IMAGE_WIDTH=512
IMAGE_HEIGHT=768
IMAGE_GEN_TIMEOUT_SEC=300
IMAGE_GEN_CONCURRENCY=4
