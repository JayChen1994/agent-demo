# 复制为 .env 后按需修改
APP_NAME=agent-demo
ENV=dev
DEBUG=true
API_PREFIX=/api/v1
HOST=127.0.0.1
PORT=8000

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=agent_demo
DB_ECHO=false

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 日志
LOG_LEVEL=INFO
LOG_DIR=logs
