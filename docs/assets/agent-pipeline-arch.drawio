        <mxCell id="sq_p2" value="PipelineService&#xa;业务层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="660" y="60" width="180" height="50" as="geometry" /></mxCell>
