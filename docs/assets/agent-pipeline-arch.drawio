        <mxCell id="sq_mC2" value="create_run(template_id, input_text)" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="450" y="910" as="sourcePoint" /><mxPoint x="750" y="910" as="targetPoint" /></mxGeometry></mxCell>
