        <mxCell id="sq_mB7" value="按注册表推导默认 DAG" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="750" y="570" as="sourcePoint" /><mxPoint x="1050" y="570" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB8" value="首次落库 / 同步注册表新增步骤（保留 enabled 选择）" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="750" y="620" as="sourcePoint" /><mxPoint x="2250" y="620" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB9" value="默认模板 nodes:[{key, enabled}] → 前端按 IO 契约分层渲染 L0..Ln" style="html=1;endArrow=open;dashed=1;endFill=0;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="2250" y="670" as="sourcePoint" /><mxPoint x="150" y="670" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB10" value="PUT /templates（开关 / 增减步骤）" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="730" as="sourcePoint" /><mxPoint x="450" y="730" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB11" value="update_template() → version+1" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="450" y="775" as="sourcePoint" /><mxPoint x="750" y="775" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mB12" value="保存 DAG（数据即流程，无需改代码）" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="750" y="805" as="sourcePoint" /><mxPoint x="2250" y="805" as="targetPoint" /></mxGeometry></mxCell>

