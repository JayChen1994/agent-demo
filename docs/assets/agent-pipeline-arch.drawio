        <mxCell id="sq_tB" value="② 编排配置阶段 · 注册表 → 默认 DAG → 开关/增减步骤（版本化入库）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#3a6a3a;" vertex="1" parent="1"><mxGeometry x="60" y="222" width="760" height="22" as="geometry" /></mxCell>
        <mxCell id="sq_tC" value="③ 执行阶段 · 后台协程：IO 契约推导依赖 → 拓扑分波并发 → Agent 回环 → SSE 实时下发" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#a8641a;" vertex="1" parent="1"><mxGeometry x="60" y="832" width="900" height="22" as="geometry" /></mxCell>

