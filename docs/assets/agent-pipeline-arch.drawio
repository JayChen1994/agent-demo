        <mxCell id="sq_selfC4" value="enabled = 启用步骤集合&#xa;asyncio.create_task(_execute)（强引用持有）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="600" y="985" width="300" height="44" as="geometry" /></mxCell>
        <mxCell id="sq_mC5" value="{ run_id, status } 立即返回（不阻塞请求）" style="html=1;endArrow=open;dashed=1;endFill=0;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="450" y="1055" as="sourcePoint" /><mxPoint x="150" y="1055" as="targetPoint" /></mxGeometry></mxCell>
