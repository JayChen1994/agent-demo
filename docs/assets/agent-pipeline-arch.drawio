        <mxCell id="sq_mC7" value="executor.run(enabled)  〔后台协程〕" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;strokeColor=#d79b00;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="750" y="1150" as="sourcePoint" /><mxPoint x="1350" y="1150" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_selfC8" value="build_dependencies()&#xa;outputs→inputs 推导依赖 + 拓扑分波" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1200" y="1185" width="300" height="44" as="geometry" /></mxCell>

        <!-- loop frame -->
        <mxCell id="sq_loop" value="loop  〔每一波 while 未完成：取就绪步骤 deps ⊆ resolved，波内 asyncio.gather 并发；缺上游产物自动 skipped〕" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d79b00;dashed=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=12;fontStyle=2;fontColor=#a8641a;" vertex="1" parent="1"><mxGeometry x="120" y="1255" width="2200" height="320" as="geometry" /></mxCell>
        <mxCell id="sq_mC9" value="波内并发 _run_one → step.run(ctx)（校验输入齐备）" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1350" y="1305" as="sourcePoint" /><mxPoint x="1650" y="1305" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_selfC10" value="kind=agent → LangGraph StateGraph：draft → critique →（有问题）revise ↺ → 通过 ✓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1470" y="1340" width="360" height="44" as="geometry" /></mxCell>
        <mxCell id="sq_mC11" value="写回黑板(outputs) + record step_run(running / completed / skipped)" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1650" y="1420" as="sourcePoint" /><mxPoint x="2250" y="1420" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mC12" value="emit step_started / step_completed · agent_round · keyframe" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1650" y="1470" as="sourcePoint" /><mxPoint x="1950" y="1470" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mC13" value="SSE 实时增量下发（节点变色 / Agent 自检 / 关键帧画廊）" style="html=1;endArrow=open;dashed=1;endFill=0;rounded=0;fontSize=12;startArrow=none;strokeColor=#82b366;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1950" y="1520" as="sourcePoint" /><mxPoint x="150" y="1520" as="targetPoint" /></mxGeometry></mxCell>

        <!-- finish -->
        <mxCell id="sq_mC14" value="PipelineRun(status=completed) + blackboard 落库" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1350" y="1610" as="sourcePoint" /><mxPoint x="2250" y="1610" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mC15" value="emit run_finished" style="html=1;endArrow=block;rounded=0;fontSize=12;startArrow=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1350" y="1650" as="sourcePoint" /><mxPoint x="1950" y="1650" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sq_mC16" value="run_finished（SSE 流结束，前端收尾）" style="html=1;endArrow=open;dashed=1;endFill=0;rounded=0;fontSize=12;startArrow=none;strokeColor=#82b366;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1950" y="1688" as="sourcePoint" /><mxPoint x="150" y="1688" as="targetPoint" /></mxGeometry></mxCell>
